KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=notification-service
KAFKA_GROUP_ID=notification-service

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Same Postgres database as pulsechat-backend — this service only reads
# (channel membership) to decide who to notify, it never writes app data.
DATABASE_URL="postgresql://pulsechat:pulsechat@localhost:5432/pulsechat?schema=public"
